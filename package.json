{
    "name": "@daanvandenbergh/scribekit",
    "version": "1.1.4",
    "description": "Drop-in, SEO-ready MDX blog and docs for Next.js App Router: server components for the post grid, articles, and a tabbed docs site, plus Claude Code skills that research and write them.",
    "license": "UNLICENSED",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "sideEffects": [
        "**/*.css"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        },
        "./react": {
            "types": "./dist/react/index.d.ts",
            "default": "./dist/react/index.js"
        },
        "./styles.css": "./dist/react/styles.css",
        "./package.json": "./package.json"
    },
    "files": [
        "dist",
        "skills",
        "demo"
    ],
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "build": "tsc -p tsconfig.build.json && cp src/react/shared/styles.css dist/react/styles.css",
        "test": "vitest run --passWithNoTests",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit",
        "demo": "npm run build && npm --prefix demo run dev",
        "docs": "npm run build && npm --prefix site run dev",
        "docs:build": "npm run build && npm --prefix site run build",
        "prepublishOnly": "npm run build",
        "push-and-publish": "git add -A && git commit -m 'Updates' && npm version patch && npm publish && git push -u origin main"
    },
    "dependencies": {
        "@daanvandenbergh/i18nkit": "^1.0.2",
        "fuse.js": "^7.4.2",
        "gray-matter": "^4.0.3",
        "remark-gfm": "^4.0.1"
    },
    "overrides": {
        "postcss": "^8.5.10"
    },
    "peerDependencies": {
        "next": ">=14",
        "next-mdx-remote": "^5 || ^6",
        "react": ">=18",
        "react-dom": ">=18"
    },
    "peerDependenciesMeta": {
        "next": {
            "optional": true
        },
        "next-mdx-remote": {
            "optional": true
        },
        "react-dom": {
            "optional": true
        }
    },
    "devDependencies": {
        "@daanvandenbergh/claudekit": "^1.0.6",
        "@types/node": "^22.20.1",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "next": "^16.2.10",
        "next-mdx-remote": "^6",
        "react": "^19",
        "react-dom": "^19",
        "server-only": "^0.0.1",
        "typescript": "^5.6.0",
        "vitest": "^3.0.0"
    }
}
